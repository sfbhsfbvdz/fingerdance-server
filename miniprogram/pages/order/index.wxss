/* pages/order/index.wxss */
.list {
  padding: 32rpx;
}

.order-card {
  margin-bottom: 24rpx;
  padding: 28rpx;
}

.order-card__top {
  display: flex;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.order-card__img {
  width: 160rpx;
  height: 160rpx;
  border-radius: 16rpx;
  flex-shrink: 0;
}

.order-card__info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 12rpx;
}

.order-card__title {
  font-size: 30rpx;
  font-weight: 600;
  color: #3D2C2C;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.order-card__date {
  font-size: 22rpx;
  color: #B8A8A8;
}

.order-card__footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 16rpx;
  border-top: 1rpx solid rgba(232, 213, 196, 0.3);
}

.order-card__price {
  font-size: 36rpx;
  font-weight: 700;
  color: #E88EA5;
}

.order-card__status {
  font-size: 26rpx;
  font-weight: 600;
}
