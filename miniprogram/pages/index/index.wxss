/* pages/index/index.wxss */

/* Hero 区 */
.hero {
  position: relative;
  height: 400rpx;
  background: linear-gradient(145deg, #F9C0CF 0%, #F4A1B5 40%, #C9956C 100%);
  overflow: hidden;
}

.hero__overlay {
  position: absolute;
  inset: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
}

.hero__logo {
  font-size: 48rpx;
  color: rgba(255,255,255,0.7);
  margin-bottom: 16rpx;
}

.hero__name {
  font-size: 48rpx;
  font-weight: 800;
  color: #fff;
  letter-spacing: 4rpx;
  text-shadow: 0 2rpx 12rpx rgba(0,0,0,0.1);
}

.hero__slogan {
  font-size: 26rpx;
  color: rgba(255,255,255,0.85);
  margin-top: 12rpx;
  letter-spacing: 2rpx;
}

/* 装饰花瓣 */
.hero__petal {
  position: absolute;
  border-radius: 50%;
  opacity: 0.15;
  background: #fff;
}
.hero__petal--1 { width: 200rpx; height: 200rpx; top: -60rpx; right: -40rpx; }
.hero__petal--2 { width: 120rpx; height: 120rpx; bottom: 20rpx; left: 30rpx; }
.hero__petal--3 { width: 80rpx; height: 80rpx; top: 40rpx; left: 120rpx; }

/* 店铺卡 */
.store-card {
  margin: -48rpx 32rpx 0;
  padding: 32rpx;
  position: relative;
  z-index: 10;
}

.store-card__main {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.store-card__avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FDE8EF, #F4A1B5);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.store-card__avatar-icon {
  font-size: 44rpx;
}

.store-card__info {
  flex: 1;
}

.store-card__name {
  font-size: 32rpx;
  font-weight: 700;
  color: #3D2C2C;
  display: block;
  margin-bottom: 8rpx;
}

.store-card__stats {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.store-card__stat {
  font-size: 24rpx;
  color: #9A8A8A;
}

.store-card__dot {
  color: #D0C0C0;
}

.store-card__actions {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.btn-service {
  flex: 1;
  height: 72rpx;
  line-height: 72rpx;
  background: rgba(244, 161, 181, 0.1);
  color: #E88EA5;
  border: 1rpx solid rgba(244, 161, 181, 0.4);
  border-radius: 40rpx;
  font-size: 26rpx;
  padding: 0;
}
.btn-service::after { border: none; }

.btn-follow {
  flex: 1;
  height: 72rpx;
  line-height: 72rpx;
  background: linear-gradient(135deg, #F4A1B5, #C9956C);
  color: #fff;
  border-radius: 40rpx;
  font-size: 26rpx;
  border: none;
  padding: 0;
}
.btn-follow--active {
  background: rgba(184, 168, 168, 0.2);
  color: #B8A8A8;
}
.btn-follow::after { border: none; }

.store-card__banner {
  background: rgba(244, 161, 181, 0.08);
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.store-card__banner-icon { font-size: 28rpx; }
.store-card__banner-text { font-size: 24rpx; color: #C9956C; font-weight: 500; }

/* 公告栏 */
.notice-bar {
  margin: 24rpx 32rpx;
  background: rgba(232, 213, 196, 0.2);
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
  overflow: hidden;
}

.notice-bar__icon { font-size: 26rpx; flex-shrink: 0; }
.notice-bar__content { flex: 1; overflow: hidden; }
.notice-bar__text {
  font-size: 24rpx;
  color: #9A7A62;
  white-space: nowrap;
  display: inline-block;
  animation: notice-scroll 16s linear infinite;
}
@keyframes notice-scroll {
  0%   { transform: translateX(100vw); }
  100% { transform: translateX(-100%); }
}
.notice-bar__arrow { color: #C9956C; font-size: 28rpx; flex-shrink: 0; }

/* 参团通知 Toast */
.join-toast {
  margin: 0 32rpx 8rpx;
  background: rgba(244, 161, 181, 0.08);
  border-radius: 12rpx;
  padding: 14rpx 20rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.join-toast__avatar {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: rgba(244, 161, 181, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  flex-shrink: 0;
}

.join-toast__text { font-size: 24rpx; color: #7A6060; }
.join-toast__name { color: #E88EA5; font-weight: 600; }

/* 活动列表 */
.section {
  padding: 0 32rpx;
}

.activities-wrap {
  padding-top: 8rpx;
}

/* 骨架屏 */
.skeleton-wrap { padding-top: 8rpx; }

.skeleton-card {
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
}

.skeleton-img {
  width: 100%;
  height: 340rpx;
  background: linear-gradient(90deg, #f0e8e8 25%, #fdf0f0 50%, #f0e8e8 75%);
  background-size: 400% 100%;
}

.skeleton-line {
  height: 24rpx;
  border-radius: 4rpx;
  margin: 20rpx 28rpx 0;
  background: #f5eaea;
}

.skeleton-line--long { width: 60%; }
.skeleton-line--short { width: 40%; margin-bottom: 28rpx; }
