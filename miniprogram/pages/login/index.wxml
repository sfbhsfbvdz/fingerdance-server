<!-- pages/login/index.wxml -->
<view class="container">

  <!-- 品牌区 -->
  <view class="brand">
    <view class="brand-logo">💅</view>
    <text class="brand-name">指尖芭蕾</text>
    <text class="brand-slogan">让美丽在指尖绽放</text>
  </view>

  <!-- 正常模式：一键登录 -->
  <view class="card" wx:if="{{!fallback}}">
    <text class="card-title">微信一键登录</text>
    <text class="card-desc">授权后即可参与拼团、查看订单</text>

    <view class="features">
      <view class="feature-item">
        <text class="feature-icon">🎀</text>
        <text class="feature-text">参与限时拼团活动</text>
      </view>
      <view class="feature-item">
        <text class="feature-icon">📋</text>
        <text class="feature-text">查看我的订单记录</text>
      </view>
      <view class="feature-item">
        <text class="feature-icon">🔒</text>
        <text class="feature-text">安全可靠，不获取手机号</text>
      </view>
    </view>

    <!-- 隐私协议勾选（默认未勾选，用户必须主动勾选）-->
    <view class="privacy-row">
      <checkbox-group bindchange="onAgreeChange">
        <checkbox value="agree" checked="{{false}}" color="#F4A1B5"/>
      </checkbox-group>
      <view class="privacy-text">
        <text class="privacy-normal">我已阅读并同意</text>
        <text class="privacy-link" bindtap="onViewPrivacy">《用户服务协议》与《隐私政策》</text>
      </view>
    </view>

    <!-- 登录按钮：未勾选时置灰 -->
    <button
      class="btn-wx-login {{!agreed ? 'btn-disabled' : ''}} {{loading ? 'loading' : ''}}"
      bindtap="onWxLogin"
    >
      <text class="btn-wx-text">{{loading ? '授权中...' : '微信一键登录'}}</text>
    </button>

    <text class="skip-btn" bindtap="onSkip">暂不登录，先逛逛</text>
  </view>

  <!-- 降级模式：手动设置头像昵称 -->
  <view class="card" wx:if="{{fallback}}">
    <text class="card-title">设置个人信息</text>
    <text class="card-desc">点击头像和输入框即可快速填入微信信息</text>

    <button
      class="avatar-btn"
      open-type="chooseAvatar"
      bindchooseavatar="onChooseAvatar"
    >
      <image wx:if="{{avatarUrl}}" src="{{avatarUrl}}" class="avatar-img" mode="aspectFill"/>
      <view wx:else class="avatar-empty">
        <text class="avatar-empty-icon">💅</text>
        <text class="avatar-empty-tip">点击选择头像</text>
      </view>
    </button>

    <view class="input-wrap">
      <input
        class="nickname-input"
        type="nickname"
        placeholder="点击填入微信昵称"
        placeholder-class="input-placeholder"
        bindblur="onNickNameBlur"
        maxlength="20"
      />
    </view>

    <!-- 隐私协议勾选 -->
    <view class="privacy-row">
      <checkbox-group bindchange="onAgreeChange">
        <checkbox value="agree" checked="{{false}}" color="#F4A1B5"/>
      </checkbox-group>
      <view class="privacy-text">
        <text class="privacy-normal">我已阅读并同意</text>
        <text class="privacy-link" bindtap="onViewPrivacy">《用户服务协议》与《隐私政策》</text>
      </view>
    </view>

    <button class="btn-confirm {{!agreed ? 'btn-disabled' : ''}}" bindtap="onConfirm">完成登录</button>
    <text class="skip-btn" bindtap="onSkip">暂不登录</text>
  </view>

</view>
