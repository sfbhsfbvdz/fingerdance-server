/* pages/activity/index.wxss */
.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #FFF9F6;
}

/* Tab 栏 */
.tabs {
  display: flex;
  background: #fff;
  padding: 0 16rpx;
  border-bottom: 1rpx solid rgba(232, 213, 196, 0.4);
  position: sticky;
  top: 0;
  z-index: 10;
}

.tab {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 28rpx 0 20rpx;
  font-size: 28rpx;
  color: #9E8E8E;
  position: relative;
}

.tab--active {
  color: #C9956C;
  font-weight: 600;
}

.tab__bar {
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 4rpx;
  background: linear-gradient(90deg, #F4A1B5, #C9956C);
  border-radius: 2rpx;
}

/* 列表 */
.list {
  flex: 1;
  overflow: hidden;
}

.list__inner {
  padding: 24rpx 32rpx 40rpx;
}

/* 骨架屏 */
.skeleton-list { padding: 24rpx 32rpx; }

.skeleton-item {
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
}

.skeleton-item__img {
  width: 100%;
  height: 340rpx;
  background: linear-gradient(90deg, #f5eaea 25%, #fdf5f5 50%, #f5eaea 75%);
  background-size: 400% 100%;
  animation: skeleton-shine 1.4s ease infinite;
}

.skeleton-item__body { padding: 24rpx 28rpx 28rpx; }

.skeleton-item__line {
  height: 24rpx;
  border-radius: 4rpx;
  margin-bottom: 16rpx;
  background: linear-gradient(90deg, #f5eaea 25%, #fdf5f5 50%, #f5eaea 75%);
  background-size: 400% 100%;
  animation: skeleton-shine 1.4s ease infinite;
}
.skeleton-item__line--long  { width: 70%; }
.skeleton-item__line--short { width: 45%; }

.skeleton-item__bar {
  height: 8rpx;
  border-radius: 4rpx;
  width: 100%;
  background: linear-gradient(90deg, #f5eaea 25%, #fdf5f5 50%, #f5eaea 75%);
  background-size: 400% 100%;
  animation: skeleton-shine 1.4s ease infinite;
  margin-top: 4rpx;
}

@keyframes skeleton-shine {
  0%   { background-position: 100% 50%; }
  100% { background-position: -100% 50%; }
}

.empty-sub {
  font-size: 24rpx;
  color: #D0C0C0;
  margin-top: 12rpx;
  display: block;
}
