/* components/activity-card/activity-card.wxss */
.card {
  background: #FFFFFF;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(244, 161, 181, 0.12);
  overflow: hidden;
  margin-bottom: 24rpx;
}

/* 图片区 */
.card__img-wrap {
  position: relative;
  width: 100%;
  height: 360rpx;
}

.card.compact .card__img-wrap {
  height: 260rpx;
}

.card__img {
  width: 100%;
  height: 100%;
}

.card__badge {
  position: absolute;
  top: 16rpx;
  left: 16rpx;
  font-size: 20rpx;
  padding: 4rpx 14rpx;
  border-radius: 20rpx;
  font-weight: 600;
}

.card__badge--active {
  background: linear-gradient(135deg, #F4A1B5, #E88EA5);
  color: #fff;
}

.card__badge--pending {
  background: rgba(232, 213, 196, 0.9);
  color: #9A7A62;
}

.card__badge--ended {
  background: rgba(0, 0, 0, 0.35);
  color: #eee;
}

.card__hot {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: linear-gradient(to top, rgba(0,0,0,0.45), transparent);
  color: #fff;
  font-size: 22rpx;
  padding: 16rpx 20rpx 12rpx;
}

/* 内容区 */
.card__body {
  padding: 24rpx 28rpx 16rpx;
}

.card__title {
  font-size: 32rpx;
  font-weight: 700;
  color: #3D2C2C;
  display: block;
  margin-bottom: 14rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.card.compact .card__title {
  font-size: 28rpx;
}

.card__tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-bottom: 16rpx;
}

/* 价格行 */
.card__price-row {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.card__save {
  font-size: 20rpx;
  color: #E88EA5;
  background: rgba(244, 161, 181, 0.12);
  padding: 2rpx 10rpx;
  border-radius: 20rpx;
}

/* 进度条 */
.card__progress {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.card__progress-bar {
  flex: 1;
  height: 8rpx;
  background: rgba(232, 213, 196, 0.4);
  border-radius: 4rpx;
  overflow: hidden;
}

.card__progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #F4A1B5, #C9956C);
  border-radius: 4rpx;
  transition: width 0.3s ease;
}

.card__progress-text {
  font-size: 22rpx;
  color: #B8A8A8;
  white-space: nowrap;
}

.card__deadline {
  font-size: 22rpx;
  color: #C8B8B8;
}

/* 底部操作栏 */
.card__footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 28rpx 24rpx;
  border-top: 1rpx solid rgba(232, 213, 196, 0.3);
}

.card__participants-count {
  font-size: 24rpx;
  color: #B8A8A8;
}

.card__action {
  background: linear-gradient(135deg, #F4A1B5 0%, #C9956C 100%);
  color: #fff;
  font-size: 26rpx;
  font-weight: 600;
  padding: 14rpx 36rpx;
  border-radius: 40rpx;
  letter-spacing: 1rpx;
}

.card__action--disabled {
  background: rgba(184, 168, 168, 0.3);
  color: #B8A8A8;
}
