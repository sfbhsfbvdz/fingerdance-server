/* pages/profile/index.wxss */

/* 顶部渐变头部 */
.profile-hero {
  background: linear-gradient(145deg, #F9C0CF, #C9956C);
  padding: 60rpx 40rpx 80rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

/* 头像按钮（微信要求用 button 包裹）*/
.avatar-btn {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  padding: 0;
  background: transparent;
  border: none;
  overflow: hidden;
}
.avatar-btn::after { border: none; }

.avatar-img {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255,255,255,0.7);
}

.avatar-placeholder {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.25);
  border: 4rpx solid rgba(255,255,255,0.5);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
}
.avatar-placeholder__icon { font-size: 52rpx; }
.avatar-placeholder__tip { font-size: 18rpx; color: rgba(255,255,255,0.85); }

/* 昵称输入区 */
.nickname-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
}

.nickname-input {
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
  text-align: center;
  background: transparent;
  border: none;
  border-bottom: 2rpx solid rgba(255,255,255,0.4);
  padding: 6rpx 20rpx;
  min-width: 200rpx;
  text-shadow: 0 2rpx 8rpx rgba(0,0,0,0.1);
}

.nickname-placeholder {
  color: rgba(255,255,255,0.6);
  font-size: 32rpx;
  font-weight: 400;
}

.nickname-edit-tip {
  font-size: 20rpx;
  color: rgba(255,255,255,0.65);
}

/* openid */
.openid-text {
  font-size: 20rpx;
  color: rgba(255,255,255,0.55);
  letter-spacing: 1rpx;
}

/* 保存按钮 */
.save-wrap {
  padding: 24rpx 32rpx 0;
}

.btn-save {
  width: 100%;
  height: 84rpx;
  line-height: 84rpx;
  background: linear-gradient(135deg, #F4A1B5, #C9956C);
  color: #fff;
  border-radius: 50rpx;
  font-size: 30rpx;
  font-weight: 700;
  border: none;
  letter-spacing: 2rpx;
}
.btn-save::after { border: none; }

/* 引导卡 */
.guide-card {
  margin: 20rpx 32rpx 0;
  background: rgba(244,161,181,0.08);
  border: 1rpx dashed rgba(244,161,181,0.4);
  border-radius: 20rpx;
  padding: 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
}
.guide-card__icon { font-size: 48rpx; }
.guide-card__title { font-size: 28rpx; font-weight: 600; color: #3D2C2C; }
.guide-card__desc { font-size: 24rpx; color: #B8A8A8; text-align: center; }

/* 订单快捷 */
.section-card { padding: 32rpx; }
.section-card__title {
  font-size: 30rpx;
  font-weight: 700;
  color: #3D2C2C;
  display: block;
  margin-bottom: 28rpx;
}

.order-shortcuts { display: flex; justify-content: space-around; }

.order-shortcut {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}
.order-shortcut__icon { font-size: 52rpx; }
.order-shortcut__label { font-size: 24rpx; color: #7A6060; }

/* 功能菜单 */
.menu-card { padding: 0 28rpx; }

.menu-item {
  display: flex;
  align-items: center;
  padding: 36rpx 0;
  gap: 20rpx;
}
.menu-item__icon { font-size: 40rpx; }
.menu-item__label { flex: 1; font-size: 30rpx; color: #3D2C2C; }
.menu-item__arrow { font-size: 36rpx; color: #D0C0C0; }

.menu-divider {
  height: 1rpx;
  background: rgba(232,213,196,0.4);
  margin-left: 60rpx;
}

/* 品牌标语 */
.brand-footer {
  text-align: center;
  padding: 48rpx 0 32rpx;
}
.brand-footer__text {
  font-size: 24rpx;
  color: #D0C0C0;
  letter-spacing: 4rpx;
}
